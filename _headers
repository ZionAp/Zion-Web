/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://static.cloudflareinsights.com https://cdn.jsdelivr.net https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https:; connect-src 'self' https://api.web3forms.com https://static.cloudflareinsights.com; frame-src 'self' https://www.openstreetmap.org https://challenges.cloudflare.com; worker-src 'self' blob:; base-uri 'self'; form-action 'self' https://api.web3forms.com; manifest-src 'self'

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: public, max-age=3600

/manifest.json
  Cache-Control: public, max-age=86400

/browserconfig.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/sw.js
  Cache-Control: no-cache, must-revalidate

/404.html
  Cache-Control: public, max-age=86400
