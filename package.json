{
  "name": "zion-web",
  "version": "1.0.0",
  "description": "Zion Appliance Solutions website",
  "scripts": {
    "optimize:css": "cssnano assets/styles.css assets/styles.min.css",
    "optimize:html": "html-minifier --collapse-whitespace --remove-comments --minify-css --minify-js --input index.html --output index.min.html",
    "audit": "npx lighthouse https://zionappliance.com --output=html --output-path=./lighthouse-report.html",
    "audit:json": "npx lighthouse https://zionappliance.com --output=json --output-path=./lighthouse-report.json",
    "svgo": "npx svgo --input assets/images --output assets/images/optimized --multipass"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "clean-css-cli": "^5.6.3",
    "cssnano": "^7.1.4",
    "html-minifier-terser": "^7.2.0",
    "jimp": "^1.6.1",
    "lighthouse": "^12.8.2",
    "particles.js": "^2.0.0",
    "playwright": "^1.59.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "aos": "^2.3.4",
    "esbuild": "^0.28.0",
    "gsap": "^3.14.2",
    "rollup": "^4.60.1",
    "terser": "^5.46.1",
    "vite": "^8.0.7",
    "webpack": "^5.106.0",
    "workbox": "^0.0.0",
    "wrangler": "^4.81.0"
  }
}
